<UserControl x:Class="ScopeAnalysis.CollectionDataProducer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="960">
    <UserControl.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Foreground" Value="#FF333333"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FieldTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FieldComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20"
              MaxWidth="980">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0"
                      Header="参数配置"
                      Margin="0,0,0,12"
                      Padding="12">
                <Grid Margin="0,2,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,0,14">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="采样率"/>
                        <ComboBox x:Name="SampleRateComboBox"
                                  Style="{StaticResource FieldComboBoxStyle}"
                                  SelectedIndex="3">
                            <ComboBoxItem Content="10M"/>
                            <ComboBoxItem Content="20M"/>
                            <ComboBoxItem Content="25M"/>
                            <ComboBoxItem Content="50M"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="2"
                                Margin="0,0,0,14">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="采样间隔"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     x:Name="BitIntervalNsTextBox"
                                     Style="{StaticResource FieldTextBoxStyle}"
                                     IsReadOnly="True"
                                     Background="#FFF5F5F5"/>
                            <TextBlock Grid.Column="1"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="#FF666666"
                                       Text="纳秒"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="4"
                                Margin="0,0,0,14">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="页大小"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     x:Name="PageSizeMbTextBox"
                                     Style="{StaticResource FieldTextBoxStyle}"
                                     Text="5"/>
                            <TextBlock Grid.Column="1"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="#FF666666"
                                       Text="MB"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Grid.Column="0"
                                Visibility="Collapsed">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="本地端口"/>
                        <TextBox x:Name="LocalPortTextBox"
                                 Style="{StaticResource FieldTextBoxStyle}"
                                 Text="6000"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="1"
                      Header="协议配置"
                      Margin="0,0,0,12"
                      Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                HorizontalAlignment="Left">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="协议类型"/>
                        <ComboBox x:Name="ProtocolTypeComboBox"
                                  Style="{StaticResource FieldComboBoxStyle}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="串口"/>
                            <ComboBoxItem Content="2 线串口"/>
                            <ComboBoxItem Content="3 线串口"/>
                            <ComboBoxItem Content="4 线串口"/>
                        </ComboBox>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Margin="0,14,0,0"
                            Padding="12"
                            Background="#FFFCFCFC"
                            BorderBrush="#FFE3E3E3"
                            BorderThickness="1"
                            CornerRadius="4">
                        <StackPanel>
                            <StackPanel x:Name="UartConfigPanel">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0"
                                                Grid.Column="0"
                                                Margin="0,0,0,14">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Text="波特率"/>
                                        <ComboBox x:Name="BaudRateComboBox"
                                                  Style="{StaticResource FieldComboBoxStyle}"
                                                  IsEditable="True"
                                                  Text="115200">
                                            <ComboBoxItem Content="9600"/>
                                            <ComboBoxItem Content="19200"/>
                                            <ComboBoxItem Content="38400"/>
                                            <ComboBoxItem Content="57600"/>
                                            <ComboBoxItem Content="115200"/>
                                            <ComboBoxItem Content="230400"/>
                                            <ComboBoxItem Content="460800"/>
                                            <ComboBoxItem Content="921600"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0"
                                                Grid.Column="2"
                                                Margin="0,0,0,14">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Text="校验位"/>
                                        <ComboBox x:Name="ParityComboBox"
                                                  Style="{StaticResource FieldComboBoxStyle}"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="无校验"/>
                                            <ComboBoxItem Content="奇校验"/>
                                            <ComboBoxItem Content="偶校验"/>
                                            <ComboBoxItem Content="标记校验"/>
                                            <ComboBoxItem Content="空格校验"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1"
                                                Grid.Column="0">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Text="数据位"/>
                                        <ComboBox x:Name="DataBitsComboBox"
                                                  Style="{StaticResource FieldComboBoxStyle}"
                                                  SelectedIndex="3">
                                            <ComboBoxItem Content="5"/>
                                            <ComboBoxItem Content="6"/>
                                            <ComboBoxItem Content="7"/>
                                            <ComboBoxItem Content="8"/>
                                            <ComboBoxItem Content="9"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1"
                                                Grid.Column="2">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Text="停止位"/>
                                        <ComboBox x:Name="StopBitsComboBox"
                                                  Style="{StaticResource FieldComboBoxStyle}"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="1"/>
                                            <ComboBoxItem Content="1.5"/>
                                            <ComboBoxItem Content="2"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <StackPanel x:Name="TwoWireConfigPanel"
                                        Visibility="Collapsed">
                                <TextBlock Style="{StaticResource FieldLabelStyle}"
                                           Text="数据速率"/>
                                <TextBox x:Name="TwoWireSamplesPerBitTextBox"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         Text="5M"/>
                            </StackPanel>

                            <StackPanel x:Name="ThreeWireConfigPanel"
                                        Visibility="Collapsed">
                                <TextBlock Style="{StaticResource FieldLabelStyle}"
                                           Text="数据速率"/>
                                <TextBox x:Name="ThreeWireSamplesPerBitTextBox"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         Text="5M"/>
                            </StackPanel>

                            <StackPanel x:Name="FourWireConfigPanel"
                                        Visibility="Collapsed">
                                <TextBlock Style="{StaticResource FieldLabelStyle}"
                                           Text="数据速率"/>
                                <TextBox x:Name="FourWireSamplesPerBitTextBox"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         Text="5M"/>
                            </StackPanel>

                            <StackPanel x:Name="ProtocolBitOrderPanel"
                                        Margin="0,14,0,0"
                                        Visibility="Collapsed">
                                <TextBlock Style="{StaticResource FieldLabelStyle}"
                                           Text="大小端"/>
                                <ComboBox x:Name="ProtocolBitOrderComboBox"
                                          Style="{StaticResource FieldComboBoxStyle}"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="BigEndian"/>
                                    <ComboBoxItem Content="LittleEndian"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </GroupBox>

            <Border Grid.Row="2"
                    Padding="12"
                    Background="#FFF8F8F8"
                    BorderBrush="#FFE0E0E0"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               x:Name="CollectionStatusTextBlock"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center"
                               Foreground="#FF666666"
                               Text="2/3/4 线按采样率 / 数据速率展开采样。"/>

                    <Button Grid.Column="1"
                            x:Name="CollectionToggleButton"
                            Content="采集"
                            MinWidth="148"
                            Height="36"
                            Padding="18,6"
                            Click="CollectionToggleButton_Click"/>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
