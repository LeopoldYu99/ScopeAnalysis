<UserControl x:Class="LCWpf.SerialPortDataProducer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:LCWpf"
             mc:Ignorable="d"
             d:DesignHeight="780" d:DesignWidth="860">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="串口配置" Margin="0,0,0,10" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="波特率:" VerticalAlignment="Center" Margin="0,5,10,5"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="BaudRateComboBox" Margin="0,5,20,5" SelectedIndex="4">
                    <ComboBoxItem Content="1200"/>
                    <ComboBoxItem Content="2400"/>
                    <ComboBoxItem Content="4800"/>
                    <ComboBoxItem Content="9600"/>
                    <ComboBoxItem Content="19200"/>
                    <ComboBoxItem Content="38400"/>
                    <ComboBoxItem Content="57600"/>
                    <ComboBoxItem Content="115200"/>
                    <ComboBoxItem Content="230400"/>
                    <ComboBoxItem Content="460800"/>
                    <ComboBoxItem Content="921600"/>
                </ComboBox>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="数据位:" VerticalAlignment="Center" Margin="0,5,10,5"/>
                <ComboBox Grid.Row="0" Grid.Column="3" x:Name="DataBitsComboBox" Margin="0,5,0,5" SelectedIndex="3" IsEnabled="False">
                    <ComboBoxItem Content="5"/>
                    <ComboBoxItem Content="6"/>
                    <ComboBoxItem Content="7"/>
                    <ComboBoxItem Content="8"/>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="停止位:" VerticalAlignment="Center" Margin="0,5,10,5"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="StopBitsComboBox" Margin="0,5,20,5" SelectedIndex="0" IsEnabled="False">
                    <ComboBoxItem Content="1"/>
                    <ComboBoxItem Content="1.5"/>
                    <ComboBoxItem Content="2"/>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="校验位:" VerticalAlignment="Center" Margin="0,5,10,5"/>
                <ComboBox Grid.Row="1" Grid.Column="3" x:Name="ParityComboBox" Margin="0,5,0,5" SelectedIndex="0" IsEnabled="False">
                    <ComboBoxItem Content="None"/>
                    <ComboBoxItem Content="Odd"/>
                    <ComboBoxItem Content="Even"/>
                    <ComboBoxItem Content="Mark"/>
                    <ComboBoxItem Content="Space"/>
                </ComboBox>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="空闲位数:" VerticalAlignment="Center" Margin="0,5,10,5"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="IdleBitsTextBox" Margin="0,5,20,5" Text="1"/>

                <TextBlock Grid.Row="3" Grid.ColumnSpan="4"
                           Text="当前按固定 8N1 生成，额外模拟一根时钟线导出为 2 线协议。"
                           Margin="0,8,0,0"
                           Foreground="Gray"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="采样率与时钟" Margin="0,0,0,10" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="采样率:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Column="1" x:Name="SampleRateTextBox" Text="50000000" IsReadOnly="True" Background="#FFF5F5F5"/>
                <TextBlock Grid.Column="2" Text="Hz" VerticalAlignment="Center" Margin="10,0,0,0"/>

                <TextBlock Grid.Column="4" Text="时钟策略:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Grid.Column="5" x:Name="ClockModeTextBlock" VerticalAlignment="Center" TextWrapping="Wrap" Foreground="Gray"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="发送数据" Margin="0,0,0,10" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="4" Text="发送内容按 ASCII 解释，并循环填充整个数据区（1016 字节）。"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="发送内容:" VerticalAlignment="Top" Margin="0,10,10,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" x:Name="PayloadSeedTextBox" Margin="0,10,0,0"
                         Text="0123456789" MinHeight="56" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="数据长度:" VerticalAlignment="Center" Margin="0,10,10,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="DurationSecondsTextBox" Margin="0,10,10,0" Text="1"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="秒" VerticalAlignment="Center" Margin="0,10,0,0"/>

                <TextBlock Grid.Row="3" Grid.ColumnSpan="4" Text="数据区预览（ASCII，仅显示前面一部分）:" Margin="0,12,0,5"/>
                <TextBox Grid.Row="4" Grid.ColumnSpan="4" x:Name="GeneratedDataPreviewTextBox" MinHeight="56" IsReadOnly="True"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Background="#FFF5F5F5"/>

                <TextBlock Grid.Row="5" Grid.ColumnSpan="4" Text="数据区预览（Hex）:" Margin="0,10,0,5"/>
                <TextBox Grid.Row="6" Grid.ColumnSpan="4" x:Name="HexPreviewTextBox" MinHeight="56" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Background="#FFF5F5F5"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="前几帧内容" Margin="0,0,0,10" Padding="10">
            <TextBox x:Name="FramePreviewTextBox" MinHeight="130" IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Background="#FFF5F5F5"/>
        </GroupBox>

        <GroupBox Grid.Row="4" Header="2 线协议预览" Margin="0,0,0,10" Padding="10">
            <TextBox x:Name="ProtocolPreviewTextBox" MinHeight="90" IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Background="#FFF5F5F5"/>
        </GroupBox>

        <GroupBox Grid.Row="5" Header="总体信息" Margin="0,0,0,10" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="InfoTextBlock" TextWrapping="Wrap" Foreground="Gray" FontFamily="Consolas"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="生成2线BIN文件" Click="GenerateBinFile_Click" Padding="20,8" FontSize="14"
                            Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        </Grid>
    </ScrollViewer>
</UserControl>
