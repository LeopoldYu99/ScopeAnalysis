<UserControl x:Class="ScopeAnalysis.SerialPortDataProducer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ScopeAnalysis"
             mc:Ignorable="d"
             d:DesignHeight="460"
             d:DesignWidth="860">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="2" Header="协议配置" Margin="0,0,0,10" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="协议类型:"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <ComboBox Grid.Row="0"
                              Grid.Column="1"
                              x:Name="ProtocolTypeComboBox"
                              SelectedIndex="0">
                        <ComboBoxItem Content="串口"/>
                        <ComboBoxItem Content="2线串口"/>
                        <ComboBoxItem Content="3线串口"/>
                        <ComboBoxItem Content="4线串口"/>
                    </ComboBox>

                    <TextBlock Grid.Row="1"
                               Grid.ColumnSpan="5"
                               Text="先完成协议配置界面，后续再接入真实的生成逻辑。"
                               Margin="0,10,0,0"/>

                    <Grid Grid.Row="2"
                          Grid.ColumnSpan="5"
                          Margin="0,12,0,0">
                        <Grid.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </Grid.Resources>

                        <StackPanel x:Name="UartConfigPanel">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="波特率:"
                                           Margin="0,0,10,0"/>
                                <ComboBox Grid.Row="0"
                                          Grid.Column="1"
                                          x:Name="BaudRateComboBox"
                                          IsEditable="True"
                                          Text="115200">
                                    <ComboBoxItem Content="9600"/>
                                    <ComboBoxItem Content="19200"/>
                                    <ComboBoxItem Content="38400"/>
                                    <ComboBoxItem Content="57600"/>
                                    <ComboBoxItem Content="115200"/>
                                    <ComboBoxItem Content="230400"/>
                                    <ComboBoxItem Content="460800"/>
                                    <ComboBoxItem Content="921600"/>
                                </ComboBox>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="2"
                                           Text="校验位:"
                                           Margin="12,0,10,0"/>
                                <ComboBox Grid.Row="0"
                                          Grid.Column="3"
                                          x:Name="ParityComboBox"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="无校验"/>
                                    <ComboBoxItem Content="奇校验"/>
                                    <ComboBoxItem Content="偶校验"/>
                                    <ComboBoxItem Content="标记校验"/>
                                    <ComboBoxItem Content="空格校验"/>
                                </ComboBox>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Text="数据位:"
                                           Margin="0,10,10,0"/>
                                <ComboBox Grid.Row="1"
                                          Grid.Column="1"
                                          x:Name="DataBitsComboBox"
                                          Margin="0,10,0,0"
                                          SelectedIndex="3">
                                    <ComboBoxItem Content="5"/>
                                    <ComboBoxItem Content="6"/>
                                    <ComboBoxItem Content="7"/>
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="9"/>
                                </ComboBox>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="2"
                                           Text="停止位:"
                                           Margin="12,10,10,0"/>
                                <ComboBox Grid.Row="1"
                                          Grid.Column="3"
                                          x:Name="StopBitsComboBox"
                                          Margin="0,10,0,0"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="1"/>
                                    <ComboBoxItem Content="1.5"/>
                                    <ComboBoxItem Content="2"/>
                                </ComboBox>
                            </Grid>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,10,0,0">
                                <Button Content="按串口协议导出 BIN"
                                        Click="ExportProtocolDataButton_Click"
                                        Padding="16,6"
                                        Cursor="Hand"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="TwoWireConfigPanel" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="CLK:"
                                           Margin="0,0,10,0"/>
                                <TextBox Grid.Column="1"
                                         x:Name="TwoWireClkTextBox"
                                         Text="F0"/>
                                <TextBlock Grid.Column="2"
                                           Text="支持配置 CLK 字节值，后续用于按 2 线格式组装数据。"
                                           Margin="12,0,0,0"
                                           TextWrapping="Wrap"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,10,0,0">
                                <Button Content="按 2 线串口协议导出 BIN"
                                        Click="ExportProtocolDataButton_Click"
                                        Padding="16,6"
                                        Cursor="Hand"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="ThreeWireConfigPanel" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="CLK:"
                                           Margin="0,0,10,0"/>
                                <TextBox Grid.Column="1"
                                         x:Name="ThreeWireClkTextBox"
                                         Text="F0"/>
                                <TextBlock Grid.Column="2"
                                           Text="EN:"
                                           Margin="12,0,10,0"/>
                                <TextBox Grid.Column="3"
                                         x:Name="ThreeWireEnTextBox"
                                         Text="0F"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,10,0,0">
                                <Button Content="按 3 线串口协议导出 BIN"
                                        Click="ExportProtocolDataButton_Click"
                                        Padding="16,6"
                                        Cursor="Hand"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="FourWireConfigPanel" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="CLK:"
                                           Margin="0,0,10,0"/>
                                <TextBox Grid.Column="1"
                                         x:Name="FourWireClkTextBox"
                                         Text="F0"/>
                                <TextBlock Grid.Column="2"
                                           Text="EN:"
                                           Margin="12,0,10,0"/>
                                <TextBox Grid.Column="3"
                                         x:Name="FourWireEnTextBox"
                                         Text="0F"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,10,0,0">
                                <Button Content="按 4 线串口协议导出 BIN"
                                        Click="ExportProtocolDataButton_Click"
                                        Padding="16,6"
                                        Cursor="Hand"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="0" Header="发送数据" Margin="0,0,0,10" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="4"
                               Text="这里只保留发送数据相关输入和预览，方便你后续继续重写生成逻辑。"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="发送内容:"
                               VerticalAlignment="Top"
                               Margin="0,10,10,0"/>
                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Grid.ColumnSpan="3"
                             x:Name="PayloadSeedTextBox"
                             Margin="0,10,0,0"
                             Text="0123456789"
                             MinHeight="56"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"/>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="时长:"
                               VerticalAlignment="Center"
                               Margin="0,10,10,0"/>
                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             x:Name="DurationSecondsTextBox"
                             Margin="0,10,10,0"
                             Text="1"/>
                    <TextBlock Grid.Row="2"
                               Grid.Column="2"
                               Text="秒"
                               VerticalAlignment="Center"
                               Margin="0,10,0,0"/>
                    <StackPanel Grid.Row="2"
                                Grid.Column="3"
                                Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <TextBlock Text="字节重复数:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBox x:Name="ByteRepeatCountTextBox"
                                 Width="90"
                                 Text="20"/>
                    </StackPanel>

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Text="空数据占比:"
                               VerticalAlignment="Center"
                               Margin="0,10,10,0"/>
                    <TextBox Grid.Row="3"
                             Grid.Column="1"
                             x:Name="EmptyDataRatioTextBox"
                             Margin="0,10,10,0"
                             Text="90"/>
                    <TextBlock Grid.Row="3"
                               Grid.Column="2"
                               Text="%"
                               VerticalAlignment="Center"
                               Margin="0,10,10,0"/>
                    <StackPanel Grid.Row="3"
                                Grid.Column="3"
                                Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <TextBlock Text="默认值:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBox x:Name="DefaultByteValueTextBox"
                                 Width="90"
                                 Text="00"/>
                    </StackPanel>

                    <TextBlock Grid.Row="4"
                               Grid.ColumnSpan="4"
                               Text="数据区预览（字符，仅显示前面一部分）:"
                               Margin="0,12,0,5"/>
                    <TextBox Grid.Row="5"
                             Grid.ColumnSpan="4"
                             x:Name="GeneratedDataPreviewTextBox"
                             MinHeight="56"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             Background="#FFF5F5F5"/>

                    <TextBlock Grid.Row="6"
                               Grid.ColumnSpan="4"
                               Text="数据区预览（十六进制）:"
                               Margin="0,10,0,5"/>
                    <TextBox Grid.Row="7"
                             Grid.ColumnSpan="4"
                             x:Name="HexPreviewTextBox"
                             MinHeight="56"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             Background="#FFF5F5F5"/>

                    <StackPanel Grid.Row="8"
                                Grid.ColumnSpan="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                        <Button Content="生成测试数据并导出 BIN"
                                Click="ExportTestDataButton_Click"
                                Padding="20,8"
                                FontSize="14"
                                Background="#007ACC"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="1" Header="采样率" Margin="0,0,0,10" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="采样率:"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1"
                             x:Name="SampleRateTextBox"
                             Text="50000000"/>
                    <TextBlock Grid.Column="2"
                               Text="Hz"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </Grid>
            </GroupBox>
        </Grid>
    </ScrollViewer>
</UserControl>
