<UserControl x:Class="LCWpf.BinFileDataProducer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="960">
    <UserControl.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Foreground" Value="#FF333333"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FieldTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FieldComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20"
              MaxWidth="980">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0"
                      Header="&#21457;&#36865;&#25968;&#25454;"
                      Margin="0,0,0,12"
                      Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,0,0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="ASCII &#20869;&#23481;"/>
                        <TextBox x:Name="PayloadAsciiTextBox"
                                 Style="{StaticResource FieldTextBoxStyle}"
                                 MinHeight="110"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top"
                                 FontFamily="Consolas"
                                 Text="ScopeAnalysis"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="2"
                                Margin="0,0,0,0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="HEX &#39044;&#35272;"/>
                        <TextBox x:Name="PayloadHexTextBox"
                                 Style="{StaticResource FieldTextBoxStyle}"
                                 MinHeight="110"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top"
                                 FontFamily="Consolas"
                                 Background="#FFF5F5F5"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Grid.ColumnSpan="3"
                            Margin="0,12,0,0"
                            Padding="10,7"
                            Background="#FFF9FAFB"
                            BorderBrush="#FFE3E7EB"
                            BorderThickness="1"
                            CornerRadius="4">
                        <TextBlock x:Name="PayloadSummaryTextBlock"
                                   Foreground="#FF415364"/>
                    </Border>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="1"
                      Header="&#21442;&#25968;&#37197;&#32622;"
                      Margin="0,0,0,12"
                      Padding="12">
                <Grid Margin="0,2,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,0,14">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="&#37319;&#26679;&#29575;"/>
                        <ComboBox x:Name="SampleRateComboBox"
                                  Style="{StaticResource FieldComboBoxStyle}"
                                  SelectedIndex="3">
                            <ComboBoxItem Content="10M"/>
                            <ComboBoxItem Content="20M"/>
                            <ComboBoxItem Content="25M"/>
                            <ComboBoxItem Content="50M"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="2"
                                Margin="0,0,0,14">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="&#37319;&#26679;&#38388;&#38548;"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     x:Name="BitIntervalNsTextBox"
                                     Style="{StaticResource FieldTextBoxStyle}"
                                     IsReadOnly="True"
                                     Background="#FFF5F5F5"/>
                            <TextBlock Grid.Column="1"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="#FF666666"
                                       Text="ns"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="4"
                                Margin="0,0,0,14">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="&#25991;&#20214;&#26102;&#38271;"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     x:Name="DurationSecondsTextBox"
                                     Style="{StaticResource FieldTextBoxStyle}"
                                     Text="1"/>
                            <TextBlock Grid.Column="1"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="#FF666666"
                                       Text="&#31186;"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="&#31354;&#25968;&#25454;&#21344;&#27604;"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     x:Name="EmptyDataRatioTextBox"
                                     Style="{StaticResource FieldTextBoxStyle}"
                                     Text="90"/>
                            <TextBlock Grid.Column="1"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="#FF666666"
                                       Text="%"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="&#31354;&#25968;&#25454;&#20540;"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     x:Name="EmptyDataValueTextBox"
                                     Style="{StaticResource FieldTextBoxStyle}"
                                     Text="0"/>
                            <TextBlock Grid.Column="1"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="#FF666666"
                                       Text="byte"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Grid.Column="4">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="Page &#22823;&#23567;"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     x:Name="PageDurationSecondsTextBox"
                                     Style="{StaticResource FieldTextBoxStyle}"
                                     Text="0.1"/>
                            <TextBlock Grid.Column="1"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="#FF666666"
                                       Text="&#31186;"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="2"
                      Header="&#21327;&#35758;&#37197;&#32622;"
                      Margin="0,0,0,12"
                      Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                HorizontalAlignment="Left">
                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="&#21327;&#35758;&#31867;&#22411;"/>
                        <ComboBox x:Name="ProtocolTypeComboBox"
                                  Style="{StaticResource FieldComboBoxStyle}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="&#20018;&#21475;"/>
                            <ComboBoxItem Content="2 &#32447;&#20018;&#21475;"/>
                            <ComboBoxItem Content="3 &#32447;&#20018;&#21475;"/>
                            <ComboBoxItem Content="4 &#32447;&#20018;&#21475;"/>
                        </ComboBox>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Margin="0,14,0,0"
                            Padding="12"
                            Background="#FFFCFCFC"
                            BorderBrush="#FFE3E3E3"
                            BorderThickness="1"
                            CornerRadius="4">
                        <Grid>
                            <StackPanel x:Name="UartConfigPanel">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0"
                                                Grid.Column="0"
                                                Margin="0,0,0,14">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Text="&#27874;&#29305;&#29575;"/>
                                        <ComboBox x:Name="BaudRateComboBox"
                                                  Style="{StaticResource FieldComboBoxStyle}"
                                                  IsEditable="True"
                                                  Text="115200">
                                            <ComboBoxItem Content="9600"/>
                                            <ComboBoxItem Content="19200"/>
                                            <ComboBoxItem Content="38400"/>
                                            <ComboBoxItem Content="57600"/>
                                            <ComboBoxItem Content="115200"/>
                                            <ComboBoxItem Content="230400"/>
                                            <ComboBoxItem Content="460800"/>
                                            <ComboBoxItem Content="921600"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0"
                                                Grid.Column="2"
                                                Margin="0,0,0,14">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Text="&#26657;&#39564;&#20301;"/>
                                        <ComboBox x:Name="ParityComboBox"
                                                  Style="{StaticResource FieldComboBoxStyle}"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="None"/>
                                            <ComboBoxItem Content="Odd"/>
                                            <ComboBoxItem Content="Even"/>
                                            <ComboBoxItem Content="Mark"/>
                                            <ComboBoxItem Content="Space"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1"
                                                Grid.Column="0">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Text="&#25968;&#25454;&#20301;"/>
                                        <ComboBox x:Name="DataBitsComboBox"
                                                  Style="{StaticResource FieldComboBoxStyle}"
                                                  SelectedIndex="3">
                                            <ComboBoxItem Content="5"/>
                                            <ComboBoxItem Content="6"/>
                                            <ComboBoxItem Content="7"/>
                                            <ComboBoxItem Content="8"/>
                                            <ComboBoxItem Content="9"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1"
                                                Grid.Column="2">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Text="&#20572;&#27490;&#20301;"/>
                                        <ComboBox x:Name="StopBitsComboBox"
                                                  Style="{StaticResource FieldComboBoxStyle}"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="1"/>
                                            <ComboBoxItem Content="1.5"/>
                                            <ComboBoxItem Content="2"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <StackPanel x:Name="TwoWireConfigPanel"
                                        Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Text="CLK"/>
                                        <TextBox x:Name="TwoWireClkTextBox"
                                                 Style="{StaticResource FieldTextBoxStyle}"
                                                 Text="F0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Text="&#25968;&#25454;&#36895;&#29575;"/>
                                        <TextBox x:Name="TwoWireSamplesPerBitTextBox"
                                                 Style="{StaticResource FieldTextBoxStyle}"
                                                 Text="5M"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <StackPanel x:Name="ThreeWireConfigPanel"
                                        Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Text="CLK"/>
                                        <TextBox x:Name="ThreeWireClkTextBox"
                                                 Style="{StaticResource FieldTextBoxStyle}"
                                                 Text="F0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Text="EN"/>
                                        <TextBox x:Name="ThreeWireEnTextBox"
                                                 Style="{StaticResource FieldTextBoxStyle}"
                                                 Text="0F"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Text="&#25968;&#25454;&#36895;&#29575;"/>
                                        <TextBox x:Name="ThreeWireSamplesPerBitTextBox"
                                                 Style="{StaticResource FieldTextBoxStyle}"
                                                 Text="5M"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <StackPanel x:Name="FourWireConfigPanel"
                                        Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Text="CLK"/>
                                        <TextBox x:Name="FourWireClkTextBox"
                                                 Style="{StaticResource FieldTextBoxStyle}"
                                                 Text="F0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Text="EN"/>
                                        <TextBox x:Name="FourWireEnTextBox"
                                                 Style="{StaticResource FieldTextBoxStyle}"
                                                 Text="0F"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                                   Text="&#25968;&#25454;&#36895;&#29575;"/>
                                        <TextBox x:Name="FourWireSamplesPerBitTextBox"
                                                 Style="{StaticResource FieldTextBoxStyle}"
                                                 Text="5M"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </GroupBox>

            <Border Grid.Row="3"
                    Padding="12"
                    Background="#FFF8F8F8"
                    BorderBrush="#FFE0E0E0"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center"
                               Foreground="#FF666666"
                               Text="2/3/4 &#32447;&#25353;&#37319;&#26679;&#29575; / &#25968;&#25454;&#36895;&#29575;&#23637;&#24320;&#37319;&#26679;&#12290;"/>

                    <Button Grid.Column="1"
                            x:Name="GenerateBinButton"
                            Content="Generate BIN"
                            MinWidth="148"
                            Height="36"
                            Padding="18,6"
                            HorizontalAlignment="Right"
                            Click="GenerateBinButton_Click"/>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
